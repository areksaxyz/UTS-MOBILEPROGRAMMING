<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#4FC3F7"
                android:centerColor="#2F80C3"
                android:endColor="#1565C0" />
        </shape>
    </item>

    <item
        android:left="-120dp"
        android:top="-120dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
            <size
                android:width="260dp"
                android:height="260dp" />
        </shape>
    </item>

    <item
        android:right="-100dp"
        android:bottom="-140dp">
        <shape android:shape="oval">
            <solid android:color="#10FFFFFF" />
            <size
                android:width="300dp"
                android:height="300dp" />
        </shape>
    </item>

</layer-list>