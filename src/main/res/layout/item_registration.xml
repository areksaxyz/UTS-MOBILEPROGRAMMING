<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/pro_surface"
    app:strokeColor="@color/pro_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRegSeminarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Web Development"
            android:textColor="@color/pro_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRegDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar pada: 12 Mei 2026"
            android:textColor="@color/pro_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/pro_border"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvRegUserName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Nama: User"
                android:textColor="@color/pro_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvRegStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BERHASIL"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
